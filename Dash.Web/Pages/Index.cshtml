@page
@model Dash.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="dashboard-shell">
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label for="userSelect" class="form-label">Usuário</label>
                    <select id="userSelect" class="form-select"></select>
                </div>
                <div class="col-12 col-md-3">
                    <label for="ownLayoutSelect" class="form-label">Meus layouts</label>
                    <select id="ownLayoutSelect" class="form-select"></select>
                </div>
                <div class="col-12 col-md-3">
                    <label for="layoutNameInput" class="form-label">Nome para salvar</label>
                    <input id="layoutNameInput" type="text" class="form-control" maxlength="120" placeholder="Ex.: Comercial semanal" />
                </div>
                <div class="col-12 col-md-3">
                    <div class="form-check mb-2">
                        <input id="shareLayoutCheck" type="checkbox" class="form-check-input" />
                        <label for="shareLayoutCheck" class="form-check-label">Disponibilizar para outros usuários</label>
                    </div>
                    <button id="saveLayoutButton" type="button" class="btn btn-primary w-100">Salvar layout atual</button>
                </div>
            </div>
            <div class="row g-3 align-items-end mt-1">
                <div class="col-12 col-md-6">
                    <label for="sharedLayoutSelect" class="form-label">Layouts compartilhados</label>
                    <select id="sharedLayoutSelect" class="form-select"></select>
                </div>
                <div class="col-6 col-md-3">
                    <button id="applySharedButton" type="button" class="btn btn-outline-secondary w-100">Aplicar compartilhado</button>
                </div>
                <div class="col-6 col-md-3">
                    <button id="resetLayoutButton" type="button" class="btn btn-outline-dark w-100">Restaurar padrão</button>
                </div>
            </div>
            <div id="dashboardMessage" class="alert mt-3 mb-0 d-none" role="alert"></div>
        </div>
    </div>

    <div id="dashboardGrid" class="grid-stack">
        <div class="grid-stack-item" gs-id="widget-monthly-revenue" gs-x="0" gs-y="0" gs-w="6" gs-h="4">
            <div class="grid-stack-item-content">
                <article class="chart-card">
                    <header class="chart-card-header">
                        <h2>Receita Mensal</h2>
                        <p>Últimos seis meses</p>
                    </header>
                    <div id="chart-monthly-revenue" class="chart-host"></div>
                </article>
            </div>
        </div>

        <div class="grid-stack-item" gs-id="widget-category-revenue" gs-x="6" gs-y="0" gs-w="6" gs-h="4">
            <div class="grid-stack-item-content">
                <article class="chart-card">
                    <header class="chart-card-header">
                        <h2>Receita por Categoria</h2>
                        <p>Participação no período</p>
                    </header>
                    <div id="chart-category-revenue" class="chart-host"></div>
                </article>
            </div>
        </div>

        <div class="grid-stack-item" gs-id="widget-orders-status" gs-x="0" gs-y="4" gs-w="12" gs-h="4">
            <div class="grid-stack-item-content">
                <article class="chart-card">
                    <header class="chart-card-header">
                        <h2>Pedidos por Status</h2>
                        <p>Comparativo do período</p>
                    </header>
                    <div id="chart-orders-status" class="chart-host"></div>
                </article>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gridstack@10.2.0/dist/gridstack.min.css" />
    <link rel="stylesheet" href="~/css/dashboard/dashboard.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/gridstack@10.2.0/dist/gridstack-all.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script type="module" src="~/js/dashboard/dashboard-page.js" asp-append-version="true"></script>
}
