@page
@model Dash.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div id="reactDashboardRoot"></div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gridstack@10.2.0/dist/gridstack.min.css" />
    <link rel="stylesheet" href="~/css/dashboard/dashboard.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/gridstack@10.2.0/dist/gridstack-all.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script type="module" src="~/js/dashboard/dashboard-app.js" asp-append-version="true"></script>
    <script type="module" src="~/js/dashboard/dashboard-page.js" asp-append-version="true"></script>
}
